<!DOCTYPE html>

<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Azivus — Intelligence Artificielle & Automatisation</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&display=swap" rel="stylesheet">
<style>
:root {
  --navy: #274472;
  --horizon: #41729F;
  --bluegray: #5885AF;
  --ice: #4A8FAB;
  --metal: #BFC3C6;
  --graphite: #4B4B4D;
  --red: #D72638;
  --white: #FFFFFF;
  --lightbg: #F0F6F8;
}

- { margin: 0; padding: 0; box-sizing: border-box; }

html { scroll-behavior: smooth; }

body {
font-family: ‘DM Sans’, sans-serif;
background: var(–white);
color: var(–graphite);
overflow-x: hidden;
}

/* ── SCROLL ANIMATIONS ── */
.reveal {
opacity: 0;
transform: translateY(40px);
transition: opacity 0.7s ease, transform 0.7s ease;
}
.reveal.visible {
opacity: 1;
transform: translateY(0);
}
.reveal-left {
opacity: 0;
transform: translateX(-50px);
transition: opacity 0.7s ease, transform 0.7s ease;
}
.reveal-left.visible { opacity: 1; transform: translateX(0); }
.reveal-right {
opacity: 0;
transform: translateX(50px);
transition: opacity 0.7s ease, transform 0.7s ease;
}
.reveal-right.visible { opacity: 1; transform: translateX(0); }

.delay-1 { transition-delay: 0.1s; }
.delay-2 { transition-delay: 0.2s; }
.delay-3 { transition-delay: 0.3s; }
.delay-4 { transition-delay: 0.4s; }
.delay-5 { transition-delay: 0.5s; }

/* ── NAV ── */
nav {
position: fixed;
top: 0; left: 0; right: 0;
z-index: 1000;
background: rgba(39,68,114,0.97);
backdrop-filter: blur(12px);
border-bottom: 2px solid var(–red);
padding: 12px 40px;
display: flex;
align-items: center;
justify-content: space-between;
}
.nav-logo {
display: flex;
align-items: center;
gap: 12px;
}
.nav-logo img { width: 38px; height: 38px; }
.nav-brand { font-family: ‘Syne’, sans-serif; font-size: 1.1rem; font-weight: 800; color: var(–white); letter-spacing: 2px; }
.nav-links { display: flex; gap: 28px; list-style: none; }
.nav-links a { color: var(–ice); text-decoration: none; font-size: 0.82rem; font-weight: 500; letter-spacing: 0.5px; transition: color 0.2s; }
.nav-links a:hover { color: var(–red); }
.nav-cta {
background: var(–red);
color: white;
padding: 8px 20px;
border-radius: 6px;
font-size: 0.82rem;
font-weight: 700;
text-decoration: none;
transition: background 0.2s, transform 0.2s;
letter-spacing: 0.5px;
}
.nav-cta:hover { background: #b01e2b; transform: translateY(-1px); }

/* ── HERO ── */
.hero {
min-height: 100vh;
background: linear-gradient(135deg, #1a2f52 0%, #274472 40%, #1e3a6e 70%, #0f1f38 100%);
position: relative;
display: flex;
align-items: center;
overflow: hidden;
padding-top: 70px;
}

/* Animated background particles */
.hero-bg {
position: absolute;
inset: 0;
overflow: hidden;
}
.hero-circle {
position: absolute;
border-radius: 50%;
border: 1px solid rgba(195,224,229,0.15);
animation: pulse-circle 6s ease-in-out infinite;
}
.hero-circle:nth-child(1) { width: 400px; height: 400px; top: -100px; right: -100px; animation-delay: 0s; }
.hero-circle:nth-child(2) { width: 600px; height: 600px; top: -200px; right: -200px; animation-delay: 1s; border-color: rgba(215,38,56,0.1); }
.hero-circle:nth-child(3) { width: 200px; height: 200px; bottom: 80px; left: -60px; animation-delay: 2s; }
.hero-dot {
position: absolute;
border-radius: 50%;
background: rgba(195,224,229,0.2);
animation: float-dot 8s ease-in-out infinite;
}
.hero-dot:nth-child(4) { width: 6px; height: 6px; top: 20%; left: 15%; animation-delay: 0s; }
.hero-dot:nth-child(5) { width: 4px; height: 4px; top: 60%; left: 25%; animation-delay: 1.5s; }
.hero-dot:nth-child(6) { width: 8px; height: 8px; top: 35%; left: 60%; animation-delay: 3s; background: rgba(215,38,56,0.4); }
.hero-dot:nth-child(7) { width: 5px; height: 5px; top: 75%; left: 70%; animation-delay: 2s; }
.hero-dot:nth-child(8) { width: 10px; height: 10px; top: 15%; left: 80%; animation-delay: 4s; }
/* Grid lines */
.hero-grid {
position: absolute;
inset: 0;
background-image:
linear-gradient(rgba(65,114,159,0.08) 1px, transparent 1px),
linear-gradient(90deg, rgba(65,114,159,0.08) 1px, transparent 1px);
background-size: 60px 60px;
}

@keyframes pulse-circle {
0%, 100% { transform: scale(1); opacity: 0.6; }
50% { transform: scale(1.05); opacity: 1; }
}
@keyframes float-dot {
0%, 100% { transform: translateY(0) scale(1); }
50% { transform: translateY(-20px) scale(1.2); }
}

.hero-content {
position: relative;
z-index: 2;
max-width: 1200px;
margin: 0 auto;
padding: 60px 40px;
display: grid;
grid-template-columns: 1fr 1fr;
gap: 60px;
align-items: center;
}

.hero-tag {
display: inline-flex;
align-items: center;
gap: 8px;
background: rgba(215,38,56,0.15);
border: 1px solid rgba(215,38,56,0.4);
color: #ff8090;
padding: 6px 16px;
border-radius: 20px;
font-size: 0.78rem;
font-weight: 600;
letter-spacing: 1.5px;
text-transform: uppercase;
margin-bottom: 24px;
animation: fadeInDown 0.8s ease both;
}

@keyframes fadeInDown {
from { opacity: 0; transform: translateY(-20px); }
to { opacity: 1; transform: translateY(0); }
}

.hero h1 {
font-family: ‘Syne’, sans-serif;
font-size: clamp(2.2rem, 4vw, 3.4rem);
font-weight: 800;
color: var(–white);
line-height: 1.1;
margin-bottom: 24px;
animation: fadeInUp 0.8s ease 0.2s both;
}
.hero h1 .accent { color: var(–red); }
.hero h1 .light { color: var(–ice); }

@keyframes fadeInUp {
from { opacity: 0; transform: translateY(30px); }
to { opacity: 1; transform: translateY(0); }
}

.hero-sub {
color: rgba(195,224,229,0.85);
font-size: 1.05rem;
line-height: 1.7;
margin-bottom: 36px;
animation: fadeInUp 0.8s ease 0.4s both;
}

.hero-pills {
display: flex;
flex-wrap: wrap;
gap: 10px;
margin-bottom: 40px;
animation: fadeInUp 0.8s ease 0.5s both;
}
.pill {
background: rgba(255,255,255,0.08);
border: 1px solid rgba(195,224,229,0.25);
color: var(–ice);
padding: 8px 16px;
border-radius: 24px;
font-size: 0.82rem;
font-weight: 500;
display: flex;
align-items: center;
gap: 6px;
transition: background 0.2s, border-color 0.2s;
}
.pill:hover { background: rgba(195,224,229,0.15); border-color: var(–ice); }
.pill .emoji { font-size: 0.95rem; }

.hero-btns {
display: flex;
gap: 16px;
flex-wrap: wrap;
animation: fadeInUp 0.8s ease 0.6s both;
}
.btn-primary {
background: var(–red);
color: white;
padding: 14px 28px;
border-radius: 8px;
font-weight: 700;
font-size: 0.95rem;
text-decoration: none;
display: inline-flex;
align-items: center;
gap: 8px;
transition: all 0.25s;
box-shadow: 0 4px 20px rgba(215,38,56,0.4);
}
.btn-primary:hover { background: #b01e2b; transform: translateY(-2px); box-shadow: 0 8px 30px rgba(215,38,56,0.5); }
.btn-secondary {
background: transparent;
color: var(–ice);
border: 1.5px solid rgba(195,224,229,0.4);
padding: 14px 28px;
border-radius: 8px;
font-weight: 600;
font-size: 0.95rem;
text-decoration: none;
display: inline-flex;
align-items: center;
gap: 8px;
transition: all 0.25s;
}
.btn-secondary:hover { border-color: var(–ice); background: rgba(195,224,229,0.08); transform: translateY(-2px); }

/* Hero right side - stats */
.hero-stats {
animation: fadeInRight 0.8s ease 0.3s both;
}
@keyframes fadeInRight {
from { opacity: 0; transform: translateX(30px); }
to { opacity: 1; transform: translateX(0); }
}
.stats-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 16px;
margin-bottom: 24px;
}
.stat-card {
background: rgba(255,255,255,0.06);
border: 1px solid rgba(195,224,229,0.2);
border-radius: 16px;
padding: 24px 20px;
text-align: center;
transition: background 0.3s, border-color 0.3s, transform 0.3s;
position: relative;
overflow: hidden;
}
.stat-card::before {
content: ‘’;
position: absolute;
top: 0; left: 0; right: 0;
height: 3px;
background: var(–red);
transform: scaleX(0);
transition: transform 0.3s;
}
.stat-card:hover { background: rgba(255,255,255,0.1); border-color: rgba(195,224,229,0.4); transform: translateY(-4px); }
.stat-card:hover::before { transform: scaleX(1); }
.stat-icon { font-size: 1.8rem; margin-bottom: 8px; }
.stat-value { font-family: ‘Syne’, sans-serif; font-size: 2rem; font-weight: 800; color: var(–white); }
.stat-label { font-size: 0.75rem; color: var(–ice); opacity: 0.8; margin-top: 4px; }

.rgpd-badge {
background: rgba(39,68,114,0.6);
border: 1px solid rgba(195,224,229,0.3);
border-radius: 12px;
padding: 16px 20px;
display: flex;
align-items: center;
gap: 14px;
}
.rgpd-icon { font-size: 2rem; }
.rgpd-text { color: var(–ice); font-size: 0.85rem; line-height: 1.5; }
.rgpd-text strong { color: var(–white); display: block; font-size: 0.92rem; margin-bottom: 2px; }

/* ── SECTION WRAPPER ── */
.section { padding: 90px 40px; }
.section-inner { max-width: 1200px; margin: 0 auto; }

.section-tag {
display: inline-flex;
align-items: center;
gap: 6px;
background: rgba(215,38,56,0.1);
border: 1px solid rgba(215,38,56,0.3);
color: var(–red);
padding: 5px 14px;
border-radius: 20px;
font-size: 0.75rem;
font-weight: 700;
letter-spacing: 1.5px;
text-transform: uppercase;
margin-bottom: 16px;
}
.section-title {
font-family: ‘Syne’, sans-serif;
font-size: clamp(1.8rem, 3vw, 2.6rem);
font-weight: 800;
color: var(–navy);
line-height: 1.2;
margin-bottom: 16px;
}
.section-title .red { color: var(–red); }
.section-subtitle {
font-size: 1.05rem;
color: var(–graphite);
opacity: 0.75;
line-height: 1.7;
max-width: 600px;
margin-bottom: 52px;
}

/* ── ABOUT ── */
.about { background: var(–lightbg); }
.about-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 60px;
align-items: start;
}
.about-left {}
.about-intro {
font-size: 1.05rem;
color: var(–graphite);
line-height: 1.8;
margin-bottom: 28px;
}
.about-highlight {
background: var(–navy);
color: white;
border-radius: 16px;
padding: 24px 28px;
display: flex;
gap: 16px;
align-items: flex-start;
margin-bottom: 28px;
}
.about-highlight .quote-icon { font-size: 2.5rem; color: var(–red); line-height: 1; margin-top: -6px; }
.about-highlight p { font-size: 0.97rem; line-height: 1.6; color: rgba(195,224,229,0.9); font-style: italic; }

.values-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 14px;
}
.value-card {
background: white;
border: 1px solid rgba(195,224,229,0.6);
border-radius: 14px;
padding: 20px;
transition: all 0.3s;
position: relative;
overflow: hidden;
}
.value-card::after {
content: ‘’;
position: absolute;
bottom: 0; left: 0; right: 0;
height: 3px;
background: var(–red);
transform: scaleX(0);
transition: transform 0.3s;
}
.value-card:hover { box-shadow: 0 8px 30px rgba(39,68,114,0.12); transform: translateY(-3px); border-color: var(–horizon); }
.value-card:hover::after { transform: scaleX(1); }
.value-icon { font-size: 1.8rem; margin-bottom: 10px; }
.value-title { font-family: ‘Syne’, sans-serif; font-size: 0.92rem; font-weight: 700; color: var(–navy); margin-bottom: 6px; }
.value-desc { font-size: 0.8rem; color: var(–graphite); opacity: 0.75; line-height: 1.55; }

.about-info { margin-top: 28px; }
.info-item {
display: flex;
align-items: center;
gap: 12px;
padding: 12px 0;
border-bottom: 1px solid rgba(195,224,229,0.5);
}
.info-item:last-child { border-bottom: none; }
.info-icon { font-size: 1.2rem; width: 32px; text-align: center; }
.info-text { font-size: 0.88rem; color: var(–graphite); }
.info-text strong { color: var(–navy); display: block; font-size: 0.82rem; margin-bottom: 1px; }

/* ── SOLUTIONS ── */
.solutions { background: white; }
.solutions-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 24px;
}
.sol-card {
background: white;
border: 1.5px solid rgba(195,224,229,0.5);
border-radius: 20px;
padding: 32px 28px;
transition: all 0.35s;
position: relative;
overflow: hidden;
}
.sol-card::before {
content: ‘’;
position: absolute;
top: 0; left: 0; right: 0;
height: 4px;
transition: background 0.3s;
}
.sol-card.blue::before { background: var(–navy); }
.sol-card.horizon::before { background: var(–horizon); }
.sol-card.red::before { background: var(–red); }
.sol-card.gray::before { background: var(–bluegray); }

.sol-card:hover {
box-shadow: 0 16px 50px rgba(39,68,114,0.14);
transform: translateY(-6px);
border-color: var(–horizon);
}
.sol-num {
font-family: ‘Syne’, sans-serif;
font-size: 3.5rem;
font-weight: 800;
color: rgba(39,68,114,0.08);
position: absolute;
top: 20px;
right: 24px;
line-height: 1;
}
.sol-header {
display: flex;
align-items: center;
gap: 14px;
margin-bottom: 16px;
}
.sol-icon-wrap {
width: 52px;
height: 52px;
border-radius: 14px;
display: flex;
align-items: center;
justify-content: center;
font-size: 1.6rem;
flex-shrink: 0;
}
.sol-card.blue .sol-icon-wrap { background: rgba(39,68,114,0.1); }
.sol-card.horizon .sol-icon-wrap { background: rgba(65,114,159,0.1); }
.sol-card.red .sol-icon-wrap { background: rgba(215,38,56,0.1); }
.sol-card.gray .sol-icon-wrap { background: rgba(88,133,175,0.1); }

.sol-title {
font-family: ‘Syne’, sans-serif;
font-size: 1.05rem;
font-weight: 700;
color: var(–navy);
line-height: 1.3;
}
.sol-desc {
font-size: 0.87rem;
color: var(–graphite);
opacity: 0.75;
line-height: 1.6;
margin-bottom: 18px;
}
.sol-items { list-style: none; display: flex; flex-direction: column; gap: 8px; }
.sol-items li {
display: flex;
align-items: center;
gap: 8px;
font-size: 0.84rem;
color: var(–graphite);
}
.sol-items li .dot {
width: 6px; height: 6px;
border-radius: 50%;
flex-shrink: 0;
}
.sol-card.blue .dot { background: var(–navy); }
.sol-card.horizon .dot { background: var(–horizon); }
.sol-card.red .dot { background: var(–red); }
.sol-card.gray .dot { background: var(–bluegray); }

/* ── BENEFITS ── */
.benefits { background: var(–navy); position: relative; overflow: hidden; }
.benefits::before {
content: ‘’;
position: absolute;
top: -200px; right: -200px;
width: 600px; height: 600px;
border-radius: 50%;
background: rgba(65,114,159,0.15);
pointer-events: none;
}
.benefits .section-title { color: white; }
.benefits .section-subtitle { color: rgba(195,224,229,0.7); }
.benefits .section-tag { background: rgba(215,38,56,0.2); border-color: rgba(215,38,56,0.5); color: #ff8090; }

.benefits-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 20px;
margin-bottom: 52px;
}
.benefit-item {
background: rgba(255,255,255,0.06);
border: 1px solid rgba(195,224,229,0.15);
border-radius: 16px;
padding: 24px;
display: flex;
gap: 16px;
align-items: flex-start;
transition: all 0.3s;
}
.benefit-item:hover { background: rgba(255,255,255,0.1); border-color: rgba(195,224,229,0.35); transform: translateX(6px); }
.benefit-icon {
width: 48px; height: 48px;
background: var(–red);
border-radius: 12px;
display: flex; align-items: center; justify-content: center;
font-size: 1.4rem;
flex-shrink: 0;
}
.benefit-title { font-family: ‘Syne’, sans-serif; font-size: 0.98rem; font-weight: 700; color: white; margin-bottom: 6px; }
.benefit-desc { font-size: 0.83rem; color: rgba(195,224,229,0.7); line-height: 1.6; }

/* Methodology */
.method-title {
font-family: ‘Syne’, sans-serif;
font-size: 1.5rem;
font-weight: 700;
color: white;
margin-bottom: 32px;
text-align: center;
}
.method-steps {
display: grid;
grid-template-columns: 1fr 1fr 1fr;
gap: 0;
position: relative;
}
.method-steps::before {
content: ‘’;
position: absolute;
top: 34px;
left: calc(16.67% + 24px);
right: calc(16.67% + 24px);
height: 2px;
background: linear-gradient(90deg, var(–red), var(–horizon), var(–ice));
}
.method-step {
display: flex;
flex-direction: column;
align-items: center;
text-align: center;
padding: 0 20px;
position: relative;
}
.step-circle {
width: 68px; height: 68px;
border-radius: 50%;
border: 3px solid var(–red);
background: var(–navy);
display: flex; align-items: center; justify-content: center;
font-size: 1.5rem;
margin-bottom: 16px;
position: relative;
z-index: 1;
transition: all 0.3s;
}
.method-step:hover .step-circle { background: var(–red); transform: scale(1.1); }
.step-num {
position: absolute;
top: -6px; right: -6px;
background: var(–red);
color: white;
width: 22px; height: 22px;
border-radius: 50%;
font-size: 0.7rem;
font-weight: 800;
display: flex; align-items: center; justify-content: center;
}
.step-title { font-family: ‘Syne’, sans-serif; font-size: 0.98rem; font-weight: 700; color: white; margin-bottom: 8px; }
.step-desc { font-size: 0.8rem; color: rgba(195,224,229,0.65); line-height: 1.6; }

/* ── USE CASES ── */
.usecases { background: var(–lightbg); }
.cases-stats {
display: grid;
grid-template-columns: repeat(3, 1fr);
gap: 20px;
margin-bottom: 52px;
}
.case-stat {
background: white;
border-radius: 16px;
padding: 28px 20px;
text-align: center;
box-shadow: 0 2px 20px rgba(39,68,114,0.07);
border: 1px solid rgba(195,224,229,0.5);
transition: all 0.3s;
}
.case-stat:hover { box-shadow: 0 8px 35px rgba(39,68,114,0.15); transform: translateY(-4px); }
.case-stat-icon { font-size: 2.2rem; margin-bottom: 10px; }
.case-stat-value { font-family: ‘Syne’, sans-serif; font-size: 2.4rem; font-weight: 800; color: var(–red); line-height: 1; }
.case-stat-label { font-size: 0.82rem; color: var(–graphite); opacity: 0.75; margin-top: 6px; line-height: 1.4; }

.cases-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 20px;
margin-bottom: 40px;
}
.case-card {
background: white;
border-radius: 16px;
padding: 24px;
border-left: 4px solid var(–navy);
box-shadow: 0 2px 16px rgba(39,68,114,0.06);
transition: all 0.3s;
}
.case-card:nth-child(2) { border-left-color: var(–red); }
.case-card:nth-child(3) { border-left-color: var(–horizon); }
.case-card:nth-child(4) { border-left-color: var(–bluegray); }
.case-card:hover { box-shadow: 0 10px 35px rgba(39,68,114,0.14); transform: translateY(-3px); }
.case-icon { font-size: 1.8rem; margin-bottom: 10px; }
.case-title { font-family: ‘Syne’, sans-serif; font-size: 0.98rem; font-weight: 700; color: var(–navy); margin-bottom: 8px; }
.case-text { font-size: 0.83rem; color: var(–graphite); opacity: 0.75; line-height: 1.65; }

.testimonial {
background: var(–navy);
border-radius: 20px;
padding: 36px 40px;
display: flex;
align-items: center;
gap: 28px;
}
.testimonial-quote {
font-size: 4rem;
color: var(–red);
line-height: 0.8;
flex-shrink: 0;
font-family: ‘Syne’, sans-serif;
}
.testimonial-text {
font-size: 1.05rem;
color: rgba(195,224,229,0.9);
font-style: italic;
line-height: 1.7;
margin-bottom: 8px;
}
.testimonial-author { font-size: 0.82rem; color: rgba(195,224,229,0.55); }

/* ── CONTACT ── */
.contact { background: linear-gradient(135deg, #1a2f52 0%, #274472 100%); position: relative; overflow: hidden; }
.contact::before {
content: ‘’;
position: absolute;
bottom: -150px; right: -150px;
width: 500px; height: 500px;
border-radius: 50%;
background: rgba(65,114,159,0.12);
}
.contact .section-title { color: white; }
.contact .section-tag { background: rgba(215,38,56,0.2); border-color: rgba(215,38,56,0.5); color: #ff8090; }

.contact-inner {
display: grid;
